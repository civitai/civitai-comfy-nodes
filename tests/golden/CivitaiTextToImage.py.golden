class CivitaiTextToImage(CivitaiRecipeNodeBase):
    """Civitai Text To Image — textToImage recipe via Civitai Orchestration."""

    RECIPE = "textToImage"
    STEP_TYPE = "textToImage"
    CATEGORY = "Civitai/Image"
    FUNCTION = "run"
    RETURN_TYPES = ('IMAGE', 'STRING', 'STRING')
    RETURN_NAMES = ('images', 'workflow_id', 'raw_json')
    FIELDS = {
        "quantity": F("quantity", "value"),
        "batch_size": F("batchSize", "value"),
        "model": F("model", "air"),
        "additional_networks": F("additionalNetworks", "network_map"),
        "control_nets": F("controlNets", "controlnet_array"),
        "prompt": F("prompt", "value"),
        "negative_prompt": F("negativePrompt", "value"),
        "scheduler": F("scheduler", "value"),
        "steps": F("steps", "value"),
        "cfg_scale": F("cfgScale", "value"),
        "width": F("width", "value"),
        "height": F("height", "value"),
        "seed": F("seed", "value"),
        "clip_skip": F("clipSkip", "value"),
        "image_metadata": F("imageMetadata", "value"),
        "engine": F("engine", "value"),
        "output_format": F("outputFormat", "value"),
        "source_image": F("sourceImage", "image_inline"),
        "source_image_denoise_strenght": F("sourceImageDenoiseStrenght", "value"),
    }
    OUTPUTS = (O("images", "image_list"),)

    @classmethod
    def INPUT_TYPES(cls):
        return {
            "required": {
                "prompt": ("STRING", {'tooltip': 'The provided text prompt.', 'default': '', 'multiline': True}),
                "cfg_scale": ("FLOAT", {'tooltip': 'The CFG scale value for image generation.', 'default': 7.5, 'min': 1.0, 'max': 30.0, 'step': 0.01}),
                "seed": ("INT", {'tooltip': 'The seed to use in image generation. Defaults to a random value if left unpopulated.', 'control_after_generate': True, 'default': 0, 'min': 0, 'max': 4294967295, 'step': 1}),
            },
            "optional": {
                "quantity": ("INT", {'tooltip': 'The number of batches to run.', 'default': 1, 'min': 1, 'max': 100, 'step': 1}),
                "batch_size": ("INT", {'tooltip': 'The size of each batch', 'default': 1, 'min': 1, 'max': 100, 'step': 1}),
                "model": ("CIVITAI_AIR", {'tooltip': 'The AIR of the checkpoint model to use for generation.'}),
                "additional_networks": ("CIVITAI_LORAS", {'tooltip': 'Get or set a associative list of additional networks. Use the AIR of the network as the key.'}),
                "control_nets": ("CIVITAI_CONTROLNETS", {'tooltip': 'Get or set a associative list of ControlNets.'}),
                "negative_prompt": ("STRING", {'tooltip': 'The provided negative text prompt.', 'default': '', 'multiline': True}),
                "scheduler": (['', 'eulerA', 'euler', 'lms', 'heun', 'dpM2', 'dpM2A', 'dpM2SA', 'dpM2M', 'dpmsde', 'dpmFast', 'dpmAdaptive', 'lmsKarras', 'dpM2Karras', 'dpM2AKarras', 'dpM2SAKarras', 'dpM2MKarras', 'dpmsdeKarras', 'ddim', 'plms', 'uniPC', 'undefined', 'lcm', 'ddpm', 'deis', 'dpM3MSDE'], {'tooltip': 'The available options for schedulers used in image generation.', 'default': ''}),
                "steps": ("INT", {'tooltip': 'The number of steps for image generation.', 'default': 30, 'min': 1, 'max': 150, 'step': 1}),
                "width": ("INT", {'tooltip': 'The desired image width in pixels.', 'default': 512, 'min': 64, 'max': 4084, 'step': 1}),
                "height": ("INT", {'tooltip': 'The desired image height in pixels.', 'default': 512, 'min': 64, 'max': 4084, 'step': 1}),
                "clip_skip": ("INT", {'tooltip': 'The clip skip value for image generation.', 'default': 2, 'min': 0, 'max': 2147483647, 'step': 1}),
                "image_metadata": ("STRING", {'tooltip': 'External metadata that will be stored with the image', 'default': ''}),
                "engine": ("STRING", {'tooltip': 'An optional engine to use for generation.', 'default': ''}),
                "output_format": (['', 'png', 'jpeg', 'webP'], {'default': ''}),
                "source_image": ("IMAGE", {'tooltip': 'An optional source image to trigger img-to-img'}),
                "source_image_denoise_strenght": ("FLOAT", {'tooltip': 'The strength/denoise factor for img2img (0.0-1.0). Lower values preserve more of the source image.', 'default': 0.8, 'min': 0.0, 'max': 2147483647.0, 'step': 0.01}),
                "api_config": ("CIVITAI_CONFIG", {"tooltip": "Optional Civitai Auth connection; defaults to CIVITAI_API_TOKEN or stored OAuth login."}),
            },
        }
