class CivitaiImageUpscaler(CivitaiRecipeNodeBase):
    """Civitai Image Upscaler — imageUpscaler recipe via Civitai Orchestration."""

    RECIPE = "imageUpscaler"
    STEP_TYPE = "imageUpscaler"
    CATEGORY = "Civitai/Image"
    FUNCTION = "run"
    RETURN_TYPES = ('IMAGE', 'STRING', 'STRING')
    RETURN_NAMES = ('blob', 'workflow_id', 'raw_json')
    FIELDS = {
        "image": F("image", "image_inline"),
        "model": F("model", "air"),
        "number_of_repeats": F("numberOfRepeats", "value"),
    }
    OUTPUTS = (O("blob", "image"),)

    @classmethod
    def INPUT_TYPES(cls):
        return {
            "required": {
                "image": ("IMAGE", {'tooltip': 'Either A URL, A DataURL or a Base64 string'}),
            },
            "optional": {
                "model": ("CIVITAI_AIR", {'tooltip': 'The upscaler model to use (AIR URN format).'}),
                "number_of_repeats": ("INT", {'tooltip': 'Number of times to repeat the upscale operation (1-3). Each repeat doubles the resolution.', 'default': 1, 'min': 1, 'max': 3, 'step': 1}),
                "api_config": ("CIVITAI_CONFIG", {"tooltip": "Optional Civitai Auth connection; defaults to CIVITAI_API_TOKEN or stored OAuth login."}),
            },
        }
